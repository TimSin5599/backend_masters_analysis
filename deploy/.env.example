# ── Secrets ───────────────────────────────────────────────────────────────────
# Единый файл конфигурации для всех сервисов.
# Скопируйте в .env и заполните реальными значениями.

# PostgreSQL
PG_USER=fqw_user
PG_PASSWORD=change_me_pg_password
PG_DB=fqw_db

# JWT (должен быть одинаковым во всех сервисах)
JWT_SIGN_KEY=change_me_long_random_secret_key

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_secret

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=change_me_rabbit_password

# Ollama
# OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_HOST=http://192.168.1.54:11434
OLLAMA_MODEL=gemma4:latest

# ── Shared service config ──────────────────────────────────────────────────────

APP_VERSION=1.0.0
LOG_LEVEL=info
PG_POOL_MAX=10

# ── Ports ─────────────────────────────────────────────────────────────────────

# PostgreSQL (host_port:5432 внутри контейнера)
PG_HOST_PORT=5435

# Go-сервисы
AUTH_PORT=8101
MANAGE_PORT=8102
STATS_PORT=8103

# Python extraction
EXTRACTION_PORT=8000

# MinIO
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Monitoring
GRAFANA_PASSWORD=change_me_grafana_password
