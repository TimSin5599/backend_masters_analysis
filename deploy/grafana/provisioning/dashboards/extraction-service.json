{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "← Overview",
      "url": "/d/overview/overview",
      "type": "link",
      "targetBlank": false,
      "icon": "arrow-left"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["extraction-service"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Extraction Service",
  "uid": "extraction-service",
  "version": 1,
  "templating": {
    "list": [
      {
        "current": {}, "hide": 0, "name": "datasource",
        "options": [], "query": "prometheus", "refresh": 1, "type": "datasource"
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Запросов / сек",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(http_requests_total{job=\"extraction-service\"}[1m]))", "instant": true, "refId": "A" }]
    },
    {
      "id": 2, "type": "stat", "title": "Ошибки AI, всего",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }
          ]}},
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(extraction_errors_total)", "instant": true, "refId": "A" }]
    },
    {
      "id": 3, "type": "stat", "title": "p95 extract (сек)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 90 }
          ]}},
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "histogram_quantile(0.95, sum by(le)(rate(extraction_duration_seconds_bucket{operation=\"extract\"}[10m])))",
        "instant": true, "refId": "A" }]
    },
    {
      "id": 4, "type": "stat", "title": "p95 classify (сек)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 30 }
          ]}},
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "histogram_quantile(0.95, sum by(le)(rate(extraction_duration_seconds_bucket{operation=\"classify\"}[10m])))",
        "instant": true, "refId": "A" }]
    },
    {
      "id": 5, "type": "timeseries", "title": "Время обработки по типу операции (p95)",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by(le, operation)(rate(extraction_duration_seconds_bucket[10m])))",
          "legendFormat": "p95 {{operation}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum by(le, operation)(rate(extraction_duration_seconds_bucket[10m])))",
          "legendFormat": "p50 {{operation}}", "refId": "B" }
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "Ошибки AI по типу операции",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 60, "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" } } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum by(operation)(rate(extraction_errors_total[5m]))",
        "legendFormat": "{{operation}}", "refId": "A" }]
    },
    {
      "id": 7, "type": "timeseries", "title": "HTTP RPS по эндпоинтам",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum by(handler)(rate(http_requests_total{job=\"extraction-service\"}[1m]))",
        "legendFormat": "{{handler}}", "refId": "A" }]
    }
  ]
}
